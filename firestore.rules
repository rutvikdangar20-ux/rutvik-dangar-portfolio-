rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /messages/{messageId} {
      allow read, write: if true;
    }

    match /project_images/{projectId} {
      allow read, write: if true;
    }

    match /stats/{id} {
      allow read, write: if true;
    }

    match /photo_views/{viewId} {
      allow read, write: if true;
    }

    match /settings/{id} {
      allow read, write: if true;
    }
  }
}
